# Copy to .env and fill in values for your environment.
# Existing shell environment variables take precedence over this file.
# Run scale, model size, and GPU memory are configured in
# course/09_runbooks/config.yaml, not in .env.

# W&B / Weave
WANDB_ENTITY=
WANDB_PROJECT=openpipe-art-retail
WANDB_API_KEY=
WEAVE_PROJECT=openpipe-art-retail

# ART local storage
ART_PATH=.art

# Dataset
RETAIL_DATASET_ID=lefft/tau-dev-task-retail-v1

# W&B model/artifact family name
ART_MODEL_NAME=retail-support-agent

# External prompted baseline / RULER judge provider
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# INFERENCE_MODEL_NAME=gpt-4.1-mini
# INFERENCE_BASE_URL=https://api.openai.com/v1
# INFERENCE_API_KEY=

# Local OpenAI-compatible endpoint example, e.g. vLLM.
# INFERENCE_BASE_URL=http://localhost:8000/v1
# INFERENCE_MODEL_NAME=Qwen/Qwen3-0.6B
# INFERENCE_API_KEY=dummy

# ART rollout behavior
ART_REQUEST_LOGPROBS=true
