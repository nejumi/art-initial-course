# Copy to .env and fill in values for your environment.
# Existing shell environment variables take precedence over this file.

# W&B / Weave
WANDB_ENTITY=
WANDB_PROJECT=openpipe-art-retail
WANDB_API_KEY=
WEAVE_PROJECT=openpipe-art-retail

# ART local storage
ART_PATH=.art

# Dataset
RETAIL_DATASET_ID=lefft/tau-dev-task-retail-v1

# Trainable model selection
# tiny      -> Qwen/Qwen3-0.6B
# standard  -> LiquidAI/LFM2.5-8B-A1B
# openpipe  -> OpenPipe/Qwen3-14B-Instruct
# serverless -> OpenPipe/Qwen3-14B-Instruct
# moe       -> Qwen/Qwen3-30B-A3B-Instruct-2507
ART_MODEL_PROFILE=standard
ART_MODEL_NAME=retail-support-agent
# ART_BASE_MODEL=LiquidAI/LFM2.5-1.2B-Instruct
# Leave unset for the course defaults. LFM2/LFM2.5, Qwen3 text models,
# Qwen3.5, and Gemma 4 choose model-specific vLLM tool parsers
# automatically when recognized.
# ART_TOOL_CALL_PARSER=lfm2
# ART_TOOL_CALL_PARSER=qwen3_xml
# ART_TOOL_CALL_PARSER=gemma4

# External prompted baseline / RULER judge provider
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# INFERENCE_MODEL_NAME=gpt-4.1-mini
# INFERENCE_BASE_URL=https://api.openai.com/v1
# INFERENCE_API_KEY=

# Local OpenAI-compatible endpoint example, e.g. vLLM.
# INFERENCE_BASE_URL=http://localhost:8000/v1
# INFERENCE_MODEL_NAME=Qwen/Qwen3-0.6B
# INFERENCE_API_KEY=dummy

# ART rollout behavior
ART_REQUEST_LOGPROBS=true
# ART_ROLLOUT_MAX_COMPLETION_TOKENS=512

# Local memory controls for larger local models.
# Qwen3.5/Gemma-class models may advertise very long context windows; capping
# both training and served context keeps activation memory and vLLM KV cache
# reservation practical for workshop GPUs.
ART_MAX_SEQ_LENGTH=8192
ART_VLLM_MAX_MODEL_LEN=16384
ART_VLLM_GPU_MEMORY_UTILIZATION=0.70
ART_VLLM_MAX_NUM_BATCHED_TOKENS=16384
ART_VLLM_MAX_NUM_SEQS=8
# ART_VLLM_ENFORCE_EAGER=false
